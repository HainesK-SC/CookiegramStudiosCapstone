# Copy this file to `.env` for local development only.
# Never commit `.env` with real credentials.

# Local development profile
SPRING_PROFILES_ACTIVE=dev

# Enable optional dev bootstrap user creation
APP_BOOTSTRAP_USERS_ENABLED=true

# Development-only login identities
BOOTSTRAP_ADMIN_EMAIL=admin.local@test.ca
BOOTSTRAP_ADMIN_PASSWORD=!rootpassword123

BOOTSTRAP_EMPLOYEE_EMAIL=employee.local@test.ca
BOOTSTRAP_EMPLOYEE_PASSWORD=!userpassword123